# =============================================================================
# Bavly KYC — Backend environment (copy to `.env`, never commit real secrets)
# =============================================================================
#
# Docker Compose: this file is loaded by `docker compose`; DATABASE_* hostnames
# are overridden in docker-compose.yml to use the `db` service. You still need
# a valid SECRET_KEY here (or only in compose `environment` if you prefer).
#
# Variable names map to Pydantic `Settings` (see app/core/config.py).
# Alembic uses DATABASE_URL_SYNC or DATABASE_URL (asyncpg → psycopg auto-replaced).
# =============================================================================

# --- Application ---
APP_NAME=KYC Management API
DEBUG=false
API_V1_PREFIX=/api/v1

# OpenAPI at /api/v1/docs when true, or when DEBUG=true
EXPOSE_DOCS=false

# --- Security (required in production) ---
# Minimum 32 characters. Generate: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Database ---
# Runtime (FastAPI): async SQLAlchemy — scheme must be postgresql+asyncpg
#
# Default local project database: bavly_kyc, superuser postgres/postgres.
# Create DB once: psql -U postgres -f scripts/create_database.sql
# Host is localhost from your OS; use hostname "db" only when API runs in Compose.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bavly_kyc
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/bavly_kyc
#
# Passwords with special characters must be URL-encoded (e.g. @ → %40).

# --- CORS ---
# Comma-separated origins, no spaces. Must include the exact browser origin
# of the SPA (scheme + host + port), e.g. https://kyc.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Business rules ---
EMPLOYEE_CAN_EDIT_OTHERS_RECORDS=false

# --- Rate limits (slowapi; examples: 10/minute, 100/hour) ---
LOGIN_RATE_LIMIT=10/minute
AUTH_REFRESH_RATE_LIMIT=30/minute
AUTH_CHANGE_PASSWORD_RATE_LIMIT=10/minute

# --- Optional: Gunicorn worker count (Docker/production image only) ---
# WEB_CONCURRENCY=2

# --- Seed script (scripts/seed_admin.py) — not read by FastAPI ---
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=ChangeMe123!
# ADMIN_FULL_NAME=مدير النظام
