# =============================================================================
# Bavly KYC — Hostinger VPS (IP-based deploy)
# =============================================================================
# Copy on the server:  cp vps.bavlykyc.env.example .env
# Run Compose from:   cd /opt/BavlyKYC/deploy && docker compose -f docker-compose.vps.yml --env-file .env up -d --build
#
# SSH (this repo uses the production VPS):
#   ssh root@187.127.142.186
#
# Public URLs (HTTP, single host — nginx proxies /api/v1 → API, /health → API):
#   SPA:  http://187.127.142.186
#   API:  http://187.127.142.186/api/v1/...
#
# When you later use a domain + HTTPS, replace CORS_ORIGINS and VITE_API_BASE_URL
# and switch to deploy/nginx.reverse-proxy.example.conf + certbot.
# =============================================================================

VPS_IP=187.127.142.186
DEPLOY_SSH=root@187.127.142.186

# --- PostgreSQL (Compose service `db`) — use a strong password ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Must match POSTGRES_* above; host name `db` is the Docker network hostname.
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/bavly_kyc
DATABASE_URL_SYNC=postgresql+psycopg://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/bavly_kyc

# --- API ---
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
DEBUG=false
EXPOSE_DOCS=false
JWT_ALGORITHM=HS256

# Exact browser origin (no trailing slash). Same host as SPA below.
CORS_ORIGINS=http://187.127.142.186

# Frontend API base (optional here). Leave unset for same-host path routing: the bundle
# uses relative `/api/v1` (browser → http://YOUR_IP/api/v1 → nginx → api).
# Set only if the SPA and API are on different origins, e.g.:
# VITE_API_BASE_URL=http://187.127.142.186/api/v1

WEB_CONCURRENCY=2

# Optional — versioned Compose image names (see deploy/docker-compose.vps.yml). If the VPS
# ever keeps an old API container, bump these (e.g. kyc-schema-v5) and run ./vps-redeploy.sh.
# BAVLYKYC_API_TAG=kyc-schema-v4
# BAVLYKYC_WEB_TAG=assets-v4

# --- Optional: seed admin (run once on server, not used by Compose) ---
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=ChangeMe123!
