# =============================================================================
# Bavly KYC — Frontend (Vite) environment
# =============================================================================
#
# Local: copy to `.env` — variables must be prefixed VITE_ to appear in the bundle.
#
# Production build:
#   - `npm run build` uses `VITE_API_BASE_URL` from the environment or this file.
#   - Docker: pass build-arg, e.g.
#       docker build --build-arg VITE_API_BASE_URL=https://api.example.com/api/v1 -t kyc-web .
#
# The URL must be reachable from the **browser** (public API origin + /api/v1 prefix).
# =============================================================================

# Base URL of the FastAPI API (no trailing slash), including /api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
